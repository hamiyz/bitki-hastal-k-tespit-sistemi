<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp"
            android:gravity="center_horizontal">

            <!-- BAŞLIK -->
            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bitki Hastalık\nTespit Sistemi"
                android:textColor="#138A36"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/opensans_bold"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="36dp" />

            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yaprak fotoğrafı çekerek hastalıkları hızlı ve doğru tespit edin."
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:fontFamily="@font/opensans_regular"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp" />

            <!-- ANA GÖRSEL / FOTOĞRAF ALANI -->
            <FrameLayout
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_image_box"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/mPhotoImageView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_leaf_scan"
                    android:scaleType="centerInside"
                    android:adjustViewBounds="true"
                    android:background="@android:color/transparent"
                    android:padding="18dp" />

            </FrameLayout>

            <!-- SON ANALİZ KARTI -->
            <LinearLayout
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:elevation="6dp"
                android:padding="16dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Son Analiz"
                    android:textColor="#138A36"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/opensans_bold" />

                <TextView
                    android:id="@+id/mResultTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Henüz analiz yapılmadı"
                    android:textColor="#1F2933"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/opensans_bold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/mResultTextView_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Güven: %0"
                    android:textColor="#138A36"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/opensans_bold"
                    android:layout_marginTop="8dp" />

                <ProgressBar
                    android:id="@+id/confidenceBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#138A36"
                    android:progressBackgroundTint="#DDE5DD" />

                <ProgressBar
                    android:id="@+id/loadingBar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/loadingText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Analiz ediliyor..."
                    android:textColor="#FF9800"
                    android:textSize="13sp"
                    android:fontFamily="@font/opensans_regular"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/warningText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Yaprak algılanamadı. Lütfen net bir yaprak fotoğrafı seçin."
                    android:textColor="#C62828"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/opensans_bold"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- FOTOĞRAF ÇEK BUTONU -->
            <Button
                android:id="@+id/mCameraButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text=" Fotoğraf Çek ve Analiz Et"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/opensans_bold"
                android:background="@drawable/bg_button_green"
                android:layout_marginBottom="12dp" />

            <!-- GALERİDEN SEÇ BUTONU -->
            <Button
                android:id="@+id/mGalleryButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text=" Galeriden Seç ve Analiz Et"
                android:textAllCaps="false"
                android:textColor="#138A36"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/opensans_bold"
                android:background="@drawable/bg_button_outline"
                android:layout_marginBottom="12dp" />

            <!-- HASTALIK DETAY BUTONU -->
            <Button
                android:id="@+id/disease_info"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Hastalık Detaylarını Göster"
                android:textAllCaps="false"
                android:textColor="#138A36"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/opensans_bold"
                android:background="@drawable/bg_button_outline"
                android:layout_marginBottom="12dp" />

            <!-- GEÇMİŞ BUTONU -->
            <Button
                android:id="@+id/historyButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Geçmiş Analizler"
                android:textAllCaps="false"
                android:textColor="#138A36"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/opensans_bold"
                android:background="@drawable/bg_button_outline"
                android:layout_marginBottom="20dp" />

            <!-- İPUCU KARTI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_green_light"
                android:elevation="3dp"
                android:padding="14dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=" İpucu"
                    android:textColor="#138A36"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/opensans_bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Daha doğru sonuç için yaprağı yakın, net ve iyi ışık alan bir ortamda çek."
                    android:textColor="#365A3A"
                    android:textSize="13sp"
                    android:fontFamily="@font/opensans_regular"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ALT MENÜ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_card_white"
        android:elevation="8dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⌂\nAna Sayfa"
            android:textColor="#138A36"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="◷\nGeçmiş"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/navAbout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="ⓘ\nHakkında"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>